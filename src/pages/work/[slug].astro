---
import "../../styles/global.css"
import { content } from "../../content"
import SiteHeader from "../../components/SiteHeader.astro"
import SiteFooter from "../../components/SiteFooter.astro"

type WorkItem = (typeof content.work.items)[number]

export async function getStaticPaths() {
  const items = content.work.items
  // Prev/next wrap around so the gallery loops continuously through all six projects.
  return items.map((item, index) => {
    const prev = items[(index - 1 + items.length) % items.length]
    const next = items[(index + 1) % items.length]
    return {
      params: { slug: item.slug },
      props: {
        item,
        index,
        total: items.length,
        prevSlug: prev.slug,
        prevTitle: prev.title,
        nextSlug: next.slug,
        nextTitle: next.title,
      },
    }
  })
}

interface Props {
  item: WorkItem
  index: number
  total: number
  prevSlug: string
  prevTitle: string
  nextSlug: string
  nextTitle: string
}

const { item, index, total, prevSlug, prevTitle, nextSlug, nextTitle } =
  Astro.props
const { meta } = content
const pageTitle = `${item.title} — ${meta.title}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={item.description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />
  </head>
  <body>
    <SiteHeader />
    <main class="mx-auto max-w-6xl px-4 pt-8 pb-16">
      <a
        href="/#work"
        class="mb-8 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <span aria-hidden="true">←</span>
        <span>Back to work</span>
      </a>

      <article
        class="rounded-3xl border border-border p-6 sm:p-10"
      >
        <header class="mb-8 flex items-start justify-between gap-4">
          <span
            class="inline-block rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold tracking-wider text-accent uppercase"
          >
            {item.category}
          </span>
        </header>

        <h1
          class="mb-2 text-3xl font-medium text-foreground sm:text-4xl md:text-5xl"
        >
          {item.title}
        </h1>
        <p class="mb-8 text-sm text-muted-foreground">
          {index + 1} of {total}
        </p>

        <div class="relative mb-10">
          <div
            class="flex aspect-[16/10] items-center justify-center overflow-hidden rounded-2xl bg-muted"
          >
            {
              item.image ? (
                <img
                  src={item.image}
                  alt={item.title}
                  class="h-full w-full object-cover"
                />
              ) : (
                <span class="text-base text-muted-foreground">
                  Project Screenshot
                </span>
              )
            }
          </div>

          <a
            href={`/work/${prevSlug}`}
            aria-label={`Previous project: ${prevTitle}`}
            class="absolute top-1/2 left-3 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-border bg-background/90 text-foreground shadow-sm transition-colors hover:bg-background sm:left-4 sm:h-12 sm:w-12"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </a>
          <a
            href={`/work/${nextSlug}`}
            aria-label={`Next project: ${nextTitle}`}
            class="absolute top-1/2 right-3 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-border bg-background/90 text-foreground shadow-sm transition-colors hover:bg-background sm:right-4 sm:h-12 sm:w-12"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>

        <p class="mb-12 max-w-3xl text-base text-foreground/80 sm:text-lg">
          {item.description}
        </p>

        <section class="mb-12">
          <h2
            class="mb-4 text-xs font-semibold tracking-wider text-muted-foreground uppercase"
          >
            Problem
          </h2>
          <ol class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {
              item.problem.map((entry, i) => (
                <li class="flex items-start gap-3 rounded-2xl bg-muted/60 p-4">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent/15 text-xs font-semibold text-accent">
                    {i + 1}
                  </span>
                  <span class="text-sm text-foreground/85">{entry}</span>
                </li>
              ))
            }
          </ol>
        </section>

        <section>
          <h2
            class="mb-4 text-xs font-semibold tracking-wider text-muted-foreground uppercase"
          >
            Approach
          </h2>
          <ol class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {
              item.approach.map((entry, i) => (
                <li class="flex items-start gap-3 rounded-2xl bg-muted/60 p-4">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent/15 text-xs font-semibold text-accent">
                    {i + 1}
                  </span>
                  <span class="text-sm text-foreground/85">{entry}</span>
                </li>
              ))
            }
          </ol>
        </section>
      </article>

      <nav
        class="mt-10 flex flex-col gap-4 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between"
        aria-label="Project navigation"
      >
        <a
          href={`/work/${prevSlug}`}
          class="group flex flex-col gap-1 text-left"
        >
          <span class="text-xs tracking-wider text-muted-foreground uppercase">
            <span aria-hidden="true">←</span> Previous
          </span>
          <span
            class="text-base text-foreground transition-colors group-hover:text-accent"
          >
            {prevTitle}
          </span>
        </a>
        <a
          href={`/work/${nextSlug}`}
          class="group flex flex-col gap-1 text-left sm:text-right"
        >
          <span class="text-xs tracking-wider text-muted-foreground uppercase">
            Next <span aria-hidden="true">→</span>
          </span>
          <span
            class="text-base text-foreground transition-colors group-hover:text-accent"
          >
            {nextTitle}
          </span>
        </a>
      </nav>
    </main>
    <SiteFooter />
  </body>
</html>
