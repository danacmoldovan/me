---
import "../../styles/global.css"
import { content } from "../../content"
import SiteHeader from "../../components/SiteHeader.astro"
import SiteFooter from "../../components/SiteFooter.astro"

type WorkItem = (typeof content.work.items)[number]

export async function getStaticPaths() {
  const items = content.work.items
  // Prev/next wrap around so the gallery loops continuously through all projects.
  return items.map((item, index) => {
    const prev = items[(index - 1 + items.length) % items.length]
    const next = items[(index + 1) % items.length]
    return {
      params: { slug: item.slug },
      props: {
        item,
        index,
        total: items.length,
        prevSlug: prev.slug,
        prevTitle: prev.title,
        nextSlug: next.slug,
        nextTitle: next.title,
      },
    }
  })
}

interface Props {
  item: WorkItem
  index: number
  total: number
  prevSlug: string
  prevTitle: string
  nextSlug: string
  nextTitle: string
}

const { item, index, total, prevSlug, prevTitle, nextSlug, nextTitle } =
  Astro.props
const galleryImages = Array.from({ length: 3 }, (_, i) => (item as any).images?.[i] ?? "")
const { meta } = content
const pageTitle = `${item.title} — ${meta.title}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={item.description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />
  </head>
  <body>
    <SiteHeader />
    <main class="mx-auto max-w-6xl px-4 pt-8 pb-16">
      <a
        href="/#work"
        class="mb-8 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <span aria-hidden="true">←</span>
        <span>Back to work</span>
      </a>

      <article>
        <header class="mb-8">
          <span id="item-category"
            class="mb-8 inline-block rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold tracking-wider text-accent"
          >
            {item.category}
          </span>
          <h1 id="item-title"
            class="mb-2 text-3xl font-medium text-foreground sm:text-4xl md:text-5xl"
          >
            {item.title}
          </h1>
          <p class="text-sm text-muted-foreground">
            {index + 1} of {total}
          </p>
        </header>

        <div id="item-image"
          class="mb-10 flex aspect-[4/3] items-center justify-center overflow-hidden rounded-2xl bg-muted"
        >
          {
            item.image ? (
              <img
                src={item.image}
                alt={item.title}
                class="h-full w-full object-cover"
              />
            ) : (
              <span class="text-base text-muted-foreground">
                Project Screenshot
              </span>
            )
          }
        </div>

        <p id="item-description" class="mb-12 text-base text-foreground/80 sm:text-lg">
          {item.description}
        </p>

        <div class="grid gap-10 lg:grid-cols-2 mb-12">
          <section id="item-problem">
            <h2
              class="mb-4 text-xs font-semibold tracking-wider text-muted-foreground uppercase"
            >
              Problem
            </h2>
            <ul class="space-y-3 rounded-2xl border border-border bg-muted p-4">
              {
                item.problem.map((entry) => (
                  <li class="border-t border-border pt-4 text-sm text-foreground/85 first:border-t-0 first:pt-0">
                    {entry}
                  </li>
                ))
              }
            </ul>
          </section>

          <section id="item-approach">
            <h2
              class="mb-4 text-xs font-semibold tracking-wider text-muted-foreground uppercase"
            >
              Approach
            </h2>
            <ul class="space-y-3 rounded-2xl border border-border bg-muted p-4">
              {
                item.approach.map((entry) => (
                  <li class="border-t border-border pt-4 text-sm text-foreground/85 first:border-t-0 first:pt-0">
                    {entry}
                  </li>
                ))
              }
            </ul>
          </section>
        </div>

        <section id="item-gallery" class="mb-12">
          <h2
            class="mb-4 text-xs font-semibold tracking-wider text-muted-foreground uppercase"
          >
            More visuals
          </h2>
          <div class="grid gap-4">
            {galleryImages.map((src, i) => (
              <div
                class={src ? "overflow-hidden rounded-3xl" : "overflow-hidden rounded-3xl border border-border bg-muted p-6 text-sm text-foreground/80 flex items-center justify-center text-center"}
              >
                <div class="aspect-[4/3] w-full">
                  {src ? (
                    <img
                      src={src}
                      alt={`${item.title} image ${i + 1}`}
                      class="h-full w-full object-cover"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center px-4 text-sm text-foreground/80">
                      <span class="max-w-[85%] leading-6">
                        More visuals coming soon. If you’re curious, feel free to get in touch for details.
                      </span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      </article>

      <nav
        class="mt-10 flex flex-col gap-4 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between"
        aria-label="Project navigation"
      >
        <a
          href={`/work/${prevSlug}`}
          class="group flex flex-col gap-1 text-left"
        >
          <span class="text-xs tracking-wider text-muted-foreground uppercase">
            <span aria-hidden="true">←</span> Previous
          </span>
          <span
            class="text-base text-foreground transition-colors group-hover:text-accent"
          >
            {prevTitle}
          </span>
        </a>
        <a
          href={`/work/${nextSlug}`}
          class="group flex flex-col gap-1 text-left sm:text-right"
        >
          <span class="text-xs tracking-wider text-muted-foreground uppercase">
            Next <span aria-hidden="true">→</span>
          </span>
          <span
            class="text-base text-foreground transition-colors group-hover:text-accent"
          >
            {nextTitle}
          </span>
        </a>
      </nav>
    </main>
    <SiteFooter />
  </body>
</html>
