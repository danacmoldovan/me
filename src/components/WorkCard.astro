---
interface Props {
  title: string
  slug: string
  category: string
  description: string
  image: string
}

const { title, slug, category, description, image } = Astro.props
---

<a
  href={`/work/${slug}`}
  class="group flex flex-col rounded-2xl outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-4 focus-visible:ring-offset-background"
  data-work-card
  data-category={category}
>
  <div
    class="mb-4 flex aspect-[4/3] items-center justify-center overflow-hidden rounded-2xl bg-muted transition-transform duration-200 group-hover:-translate-y-0.5"
  >
    {
      image ? (
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      ) : (
        <span class="px-6 text-center text-base text-foreground/70">
          {title}
        </span>
      )
    }
  </div>

  <p
    class="mb-2 text-xs font-semibold tracking-wider text-accent"
  >
    {category}
  </p>
  <h3
    class="mb-2 text-xl font-medium text-foreground transition-colors group-hover:text-accent"
  >
    {title}
  </h3>
  <p class="text-sm text-muted-foreground">{description}</p>
</a>
