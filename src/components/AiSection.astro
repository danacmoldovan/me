---
import { content } from "../content"
const { ai } = content
---

<section id="ai" class="scroll-mt-20 py-16">
  <h2 class="mb-4 text-3xl font-medium text-foreground md:text-4xl">
    {ai.title}
  </h2>
  <p class="mb-4 text-base text-muted-foreground">{ai.description}</p>
  <div class="mt-8 w-full">
    <div class="rounded-3xl bg-muted/40 p-6 w-full">
      <p class="mb-4 text-lg font-medium text-foreground">{ai.content[0]}</p>

      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl bg-background p-6 text-foreground border border-border">
          <p class="text-sm">{ai.content[1]}</p>
        </div>
        <div class="rounded-2xl bg-background p-6 text-foreground border border-border">
          <p class="text-sm">{ai.content[2]}</p>
        </div>
      </div>
    </div>
  </div>
</section>
