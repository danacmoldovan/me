#!/bin/sh
set -e

files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(astro|ts|tsx|js|jsx|mjs|cjs|css)$' || true)

if [ -z "$files" ]; then
  echo "no source changes; skipping check"
  exit 0
fi

# astro check covers .astro + .ts type-checking project-wide.
# Project-wide because a change in one file can break types elsewhere.
echo "→ astro check"
npm run check
